[Unit]
Description=JGMAO Chat Relay
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/jgmao-official-site
EnvironmentFile=/home/ubuntu/jgmao-official-site/deploy/jgmao-chat-relay.env
ExecStart=/usr/bin/node /home/ubuntu/jgmao-official-site/scripts/server-chat-relay.mjs
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
